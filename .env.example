# LLM
# When running via docker-compose, 9router runs as sidecar at http://router:20128/v1.
# For local dev outside docker, point to your local 9router (typically http://localhost:20128/v1).
LLM_BASE_URL=http://router:20128/v1
LLM_API_KEY=changeme

# IG
IG_USERNAME=changeme
IG_PASSWORD=changeme

# Data sources
NEWSAPI_KEY=changeme
GNEWS_KEY=changeme
TWELVEDATA_KEY=changeme

# Notifier
TELEGRAM_BOT_TOKEN=changeme
TELEGRAM_CHAT_ID=changeme

# Runtime
APP_ENV=dev

# Offsite backup target. Examples:
#   user@host:/backups/ig-qt           (rsync over SSH)
#   rclone:b2:my-bucket/ig-qt          (rclone remote)
#   /mnt/backups/ig-qt                 (local mount)
BACKUP_DEST=
